{
  "name": "eldanmtz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "TINA_PUBLIC_IS_LOCAL=true tinacms dev -c \"next dev\"",
    "validate": "node scripts/validate-content.mjs",
    "test": "node --disable-warning=ExperimentalWarning --experimental-strip-types --test \"tests/**/*.test.ts\"",
    "prebuild": "node scripts/validate-content.mjs",
    "build": "tinacms build --skip-cloud-checks && next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.9",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "@tinacms/cli": "^2.5.1",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tinacms": "^3.9.3",
    "typescript": "^5"
  },
  "overrides": {
    "react-final-form": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
