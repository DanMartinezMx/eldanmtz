# Copy to .env and fill in for TinaCMS Cloud editing / the production admin.
# For local-only editing (npm run dev), these can be left as-is.

# Git branch TinaCMS reads/writes. Defaults to "main" if unset.
NEXT_PUBLIC_TINA_BRANCH=main

# TinaCMS Cloud project credentials (required for cloud editing & /admin in prod).
# Get these from https://app.tina.io — do NOT commit real values.
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=
